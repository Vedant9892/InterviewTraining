# InterviewTraining Environment Variables

# AI Services (Choose ONE)
OPENAI_API_KEY=your_openai_api_key_here
# NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_AI_PROVIDER=openai

# Face Recognition - Backend API URL (when using server-side analysis)
NEXT_PUBLIC_FACE_RECOGNITION_API=http://localhost:3001/api/face-recognition

# Feature Flags
NEXT_PUBLIC_ENABLE_VIDEO_ANALYSIS=true
NEXT_PUBLIC_ENABLE_AUDIO_ANALYSIS=true
